<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FermentaCraft — Plan. Brew. Perfect.</title>
  <meta name="description" content="FermentaCraft: plan recipes, track fermentation, manage inventory, and use pro tools for cider, mead, and fruit wines." />
  <link rel="canonical" href="https://fermentacraft.com/">
  <meta property="og:title" content="FermentaCraft — Plan. Brew. Perfect.">
  <meta property="og:description" content="Plan recipes, track fermentation, manage inventory, and use pro tools for cider, mead, and fruit wines.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://fermentacraft.com/">
  <meta property="og:image" content="https://fermentacraft.com/screenshots/cover1.png">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#0f172a">
  <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b1022">

  <style>
    :root{
      --bg: #0b1022;          /* dark indigo */
      --bg-soft:#0e1530;
      --text:#e7eaf3;         /* light text */
      --muted:#a8b1c7;
      --brand:#7dd3fc;        /* sky-ish accent */
      --brand-2:#60a5fa;      /* blue accent */
      --card:#101938;
      --border:#233055;
      --ring:#5eead4;         /* cyan ring */
      --btn:#111827;          /* neutral btn bg (light) */
      --btn-border:#1f2a44;
      --shadow: 0 10px 30px rgba(0,0,0,.35);
      --radius: 16px;
      --radius-lg: 24px;
      --container: 1200px;
    }
    @media (prefers-color-scheme: light){
      :root{
        --bg: #f8fafc;
        --bg-soft:#f1f5f9;
        --text:#0f172a;
        --muted:#475569;
        --brand:#0284c7;
        --brand-2:#2563eb;
        --card:#ffffff;
        --border:#e2e8f0;
        --btn:#0f172a;
        --btn-border:#cbd5e1;
        --shadow: 0 10px 24px rgba(15,23,42,.12);
      }
    }

    * { box-sizing:border-box; }
    html,body { height:100%; }
    body{
      margin:0;
      color:var(--text);
      background:
        radial-gradient(1200px 800px at 80% -10%, rgba(96,165,250,.18), transparent 50%),
        radial-gradient(1000px 700px at -10% 20%, rgba(125,211,252,.2), transparent 50%),
        linear-gradient(180deg, var(--bg) 0%, var(--bg-soft) 100%);
      font-family: system-ui, -apple-system, Segoe UI, Roboto, Inter, "Helvetica Neue", Arial, "Noto Sans", "Apple Color Emoji","Segoe UI Emoji", "Segoe UI Symbol";
      line-height:1.6;
    }

    .container{ max-width:var(--container); margin-inline:auto; padding:24px; }
    header{
      position:sticky; top:0; z-index:10;
      backdrop-filter: saturate(1.1) blur(8px);
      background: color-mix(in oklab, var(--bg) 70%, transparent);
      border-bottom: 1px solid var(--border);
    }
    .nav{
      display:flex; align-items:center; justify-content:space-between;
      padding: 14px 0;
    }
    .logo{
      display:flex; align-items:center; gap:12px; text-decoration:none; color:var(--text);
      font-weight:700; letter-spacing:.2px; font-size:18px;
    }
    .logo-dot{ width:12px; height:12px; border-radius:50%;
      background: radial-gradient(circle at 30% 30%, var(--ring), var(--brand-2));
      box-shadow: 0 0 0 6px color-mix(in oklab, var(--ring) 25%, transparent);
    }
    .top-links a{
      color:var(--muted); text-decoration:none; margin-left:18px; font-weight:600;
    }
    .top-links a:hover{ color:var(--text); }

    .hero{
      display:grid; gap:28px; align-items:center;
      grid-template-columns: 1.2fr .8fr;
      padding: 40px 0 10px;
    }
    @media (max-width: 980px){
      .hero{ grid-template-columns: 1fr; padding-top: 32px; }
    }
    .eyebrow{
      display:inline-flex; align-items:center; gap:10px;
      padding:6px 12px; border:1px solid var(--border); border-radius:999px;
      background: color-mix(in oklab, var(--card) 80%, transparent);
      color:var(--muted); font-weight:600; font-size:12px; letter-spacing:.3px;
    }
    h1{
      margin: 14px 0 10px; line-height:1.15;
      font-size: clamp(28px, 4.4vw, 52px);
      letter-spacing:-.5px;
    }
    .lede{ color:var(--muted); font-size: clamp(15px, 2vw, 18px); max-width: 56ch; }

    .cta{
      display:flex; flex-wrap:wrap; gap:12px; margin-top: 20px;
    }
    .btn{
      display:inline-flex; align-items:center; gap:10px;
      padding: 14px 18px; border-radius: 14px; border:1px solid var(--btn-border);
      background: color-mix(in oklab, var(--card) 90%, transparent);
      color:var(--text); font-weight:700; text-decoration:none; letter-spacing:.2px;
      box-shadow: var(--shadow);
      transition: transform .15s ease, background .2s ease, border-color .2s ease;
    }
    .btn:hover{ transform: translateY(-2px); background: color-mix(in oklab, var(--card) 95%, transparent); border-color: color-mix(in oklab, var(--btn-border) 60%, var(--brand-2)); }
    .btn:focus-visible{ outline: 2px solid var(--brand-2); outline-offset:2px; }
    .btn .icon{ width:20px; height:20px; display:inline-block; }
    .btn.primary{
      background: linear-gradient(135deg, var(--brand-2), var(--brand));
      border-color: transparent;
    }
    .btn.primary:hover{ transform: translateY(-2px); filter: saturate(1.1) brightness(1.02); }

    .panel{
      border:1px solid var(--border); border-radius: var(--radius-lg);
      background:
        radial-gradient(600px 300px at 60% -10%, color-mix(in oklab, var(--brand) 18%, transparent), transparent),
        var(--card);
      padding: 18px; box-shadow: var(--shadow);
    }
    .device-mock{
      aspect-ratio: 16/10; border-radius: 14px; overflow: hidden; position:relative;
      background:
        linear-gradient(180deg, color-mix(in oklab, var(--bg) 40%, transparent), transparent),
        radial-gradient(1200px 600px at -20% 0%, color-mix(in oklab, var(--brand) 20%, transparent), transparent),
        #0a0f22;
      border:1px solid var(--border);
    }
    .device-mock img{
      position:absolute; inset:0; width:100%; height:100%; object-fit:cover; opacity:.9;
    }
    .band{
      margin: 34px 0 10px;
      display:grid; gap:16px; grid-template-columns: repeat(3, 1fr);
    }
    @media (max-width: 980px){ .band{ grid-template-columns: 1fr; } }

    .card{
      border:1px solid var(--border); border-radius: var(--radius);
      background: var(--card); padding:18px;
    }
    .card h3{ margin:0 0 8px; font-size:18px; letter-spacing:.2px; }
    .card p{ margin:0; color:var(--muted); }

    footer{
      border-top:1px solid var(--border);
      margin-top: 40px; padding: 28px 0; color:var(--muted);
    }
    .foot{ display:flex; gap:16px; flex-wrap:wrap; }
    .foot a{ color:inherit; text-decoration:none; }
    .foot a:hover{ color:var(--text); text-decoration: underline; }

    /* helper to hide-only-visually if needed */
    .visually-hidden{ position:absolute !important; width:1px; height:1px; margin:-1px; border:0; padding:0; white-space:nowrap; clip-path: inset(50%); clip: rect(0 0 0 0); overflow:hidden; }
  </style>
</head>
<body>
  <header>
    <div class="container nav">
      <a class="logo" href="/">
        <span class="logo-dot" aria-hidden="true"></span>
        <span>FermentaCraft</span>
      </a>
      <nav class="top-links" aria-label="Secondary">
        <a href="https://app.fermentacraft.com" rel="noopener">Web App</a>
        <a href="mailto:support@fermentacraft.com">Support</a>
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
      </nav>
    </div>
  </header>

  <main class="container">
    <section class="hero" aria-labelledby="home-title">
      <div>
        <span class="eyebrow">Cider • Mead • Fruit Wines</span>
        <h1 id="home-title">Plan. Brew. Perfect.</h1>
        <p class="lede">
          Build better recipes, track fermentation like a pro, manage ingredients,
          and use tools that actually earn their keep — all in one streamlined app.
        </p>

        <div class="cta" role="group" aria-label="Download and launch">
          <!-- Launch Web App -->
          <a class="btn primary" href="https://app.fermentacraft.com" rel="noopener">
            <!-- globe -->
            <svg class="icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.7"></circle>
              <path d="M3 12h18M12 3c2.8 3 2.8 15 0 18M12 3c-2.8 3-2.8 15 0 18" stroke="currentColor" stroke-width="1.7"></path>
            </svg>
            Launch Web App
          </a>

          <!-- Download for Windows -->
          <a class="btn" href="https://github.com/mrcrunchybeans/FermentaCraft/releases/latest" rel="noopener">
            <!-- Windows logo -->
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M2 4.5l9-1.3v9.1H2V4.5zm9 7.2h11V2.6L11 4v7.7zM2 12.9h9V22L2 20.6v-7.7zm11 0h11v8.5L13 22v-9.1z"/>
            </svg>
            Download for Windows
          </a>

          <!-- Microsoft Store (light/dark badge via <picture>) -->
          <a class="btn" href="https://apps.microsoft.com/store/detail/9NVPD2KZ19DB" rel="noopener" aria-label="Get from Microsoft Store">
            <picture aria-hidden="true" class="icon" style="display:inline-block">
              <source media="(prefers-color-scheme: dark)" srcset="https://static.wikia.nocookie.net/logopedia/images/b/bf/Microsoft_Store_2021_Dark.svg">
              <img src="https://static.wikia.nocookie.net/logopedia/images/d/df/Microsoft_Store_2021_Light.svg" alt="" style="width:20px;height:20px;display:block">
            </picture>
            Get from Microsoft Store
          </a>

          <!-- Google Play -->
          <a class="btn" href="https://play.google.com/store/apps/details?id=com.fermentacraft" rel="noopener">
            <!-- Play icon -->
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="currentColor" d="M3 4.6v14.8c0 .7.8 1.1 1.4.7l10.8-7.4c.5-.4.5-1.1 0-1.5L4.4 3.9C3.8 3.5 3 3.9 3 4.6z"/>
              <path fill="currentColor" d="M16.8 8.2L14 10l2.8 1.8 3.2-1.8c.8-.5.8-1.8 0-2.2l-3.2-1.8z" opacity=".7"/>
            </svg>
            Get on Google Play
          </a>
        </div>
      </div>

      <div class="panel" aria-hidden="true">
        <div class="device-mock">
          <!-- Optional: replace with your own hero screenshot(s) -->
          <!-- <img src="/screenshots/01.png" alt=""> -->
        </div>
      </div>
    </section>

    <section class="band" aria-label="Highlights">
      <article class="card">
        <h3>Recipe Builder</h3>
        <p>Create structured recipes with fermentables, additives, ABV/FG math, gravity tools, and reusable profiles.</p>
      </article>
      <article class="card">
        <h3>Fermentation Tracking</h3>
        <p>Log SG, temperature, and notes. Visualize progress over time with clean, readable charts.</p>
      </article>
      <article class="card">
        <h3>Tools that Earn Their Keep</h3>
        <p>SO2 estimator, gravity adjustment, acidity & pH helpers, hydrometer temp correction, and more.</p>
      </article>
    </section>
  </main>

  <footer>
    <div class="container">
      <div class="foot" role="contentinfo">
        <span>© <span id="y">2025</span> FermentaCraft</span>
        <span>•</span>
        <a href="https://app.fermentacraft.com" rel="noopener">Web App</a>
        <span>•</span>
        <a href="mailto:support@fermentacraft.com">Support</a>
        <span>•</span>
        <a href="/privacy">Privacy</a>
        <span>•</span>
        <a href="/terms">Terms</a>
      </div>
    </div>
    <!-- The small inline script below only updates the year text node without frameworks.
         Remove it if you want *zero* JS; then replace 2025 manually in the markup. -->
    <script>document.getElementById('y').textContent = new Date().getFullYear();</script>
  </footer>
</body>
</html>
