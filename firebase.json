{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "fermentacraft",
          "appId": "1:747130944683:android:c8e4ec77afd61d483b0bee",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "fermentacraft",
          "configurations": {
            "android": "1:747130944683:android:c8e4ec77afd61d483b0bee",
            "ios": "1:747130944683:ios:9e36933548b34a263b0bee",
            "web": "1:747130944683:web:8a2db0e33d8acbed3b0bee",
            "windows": "1:747130944683:web:78884c5827e0c0793b0bee"
          }
        }
      }
    }
  },

  "firestore": {
    "rules": "lib/firestore.rules"
  },

  "hosting": {
    "public": "build/web",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/ingest", "function": { "functionId": "ingest", "region": "us-central1" } }
    ]
  },

  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": ["node_modules", ".git", "firebase-debug.log", "firebase-debug.*.log", "*.local"],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ]
    }
  ]
}
