<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- App basics -->
  <key>CFBundleDevelopmentRegion</key>
  <string>$(DEVELOPMENT_LANGUAGE)</string>
  <key>CFBundleDisplayName</key>
  <string>FermentaCraft</string>
  <key>CFBundleExecutable</key>
  <string>$(EXECUTABLE_NAME)</string>
  <key>CFBundleIdentifier</key>
  <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>FermentaCraft</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>1.0.0</string>
  <key>CFBundleSignature</key>
  <string>????</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSRequiresIPhoneOS</key>
  <true/>

  <!-- Launch screen -->
  <key>UILaunchStoryboardName</key>
  <string>LaunchScreen</string>

  <!-- Orientation -->
  <key>UISupportedInterfaceOrientations</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>
  <key>UISupportedInterfaceOrientations~ipad</key>
  <array>
    <string>UIInterfaceOrientationPortrait</string>
    <string>UIInterfaceOrientationPortraitUpsideDown</string>
    <string>UIInterfaceOrientationLandscapeLeft</string>
    <string>UIInterfaceOrientationLandscapeRight</string>
  </array>

  <!-- Flutter perf tweaks -->
  <key>UIApplicationSupportsIndirectInputEvents</key>
  <true/>
  <key>CADisableMinimumFrameDurationOnPhone</key>
  <true/>

  <!-- TEMP: allow HTTP while verifying. Remove or narrow once all endpoints are HTTPS. -->
  <key>NSAppTransportSecurity</key>
  <dict>
    <key>NSAllowsArbitraryLoads</key>
    <true/>
  </dict>

  <!-- url_launcher: only the schemes you actually query -->
  <key>LSApplicationQueriesSchemes</key>
  <array>
    <string>mailto</string>
    <string>sms</string>
    <string>tel</string>
  </array>

  <!-- Google Sign-In (ONLY if you use it). Replace with REVERSED_CLIENT_ID from GoogleService-Info.plist -->
  <key>CFBundleURLTypes</key>
  <array>
    <dict>
      <key>CFBundleURLSchemes</key>
      <array>
        <string>com.googleusercontent.apps.747130944683-add6ufd63i82lh8ispnosi2ii3vu6hbn</string>
      </array>
    </dict>
  </array>

  <!-- Permissions you already use / may need -->
  <key>NSCameraUsageDescription</key>
  <string>Take photos of pH strips and fermentation equipment for batch documentation</string>
  <key>NSPhotoLibraryUsageDescription</key>
  <string>Select photos for batch documentation and recipe images</string>
  <key>NSPhotoLibraryAddUsageDescription</key>
  <string>Save fermentation photos and batch documentation to your library</string>
  
  <!-- Sprint 2.5: Additional iOS permissions -->
  <key>NSDocumentsFolderUsageDescription</key>
  <string>Save recipe exports and batch data backups</string>
  <key>NSFileProviderDomainUsageDescription</key>
  <string>Access cloud storage for recipe and batch data synchronization</string>

  <!-- Optional: disable Impeller while diagnosing GPU/splash issues -->
  <key>FLTEnableImpeller</key>
  <false/>
  
  <!-- Sprint 2.5: iOS App lifecycle and background modes -->
  <key>UIBackgroundModes</key>
  <array>
    <string>background-fetch</string>
    <string>background-processing</string>
  </array>
  
  <!-- iOS-specific app category for App Store -->
  <key>LSApplicationCategoryType</key>
  <string>public.app-category.food-and-drink</string>

</dict>
</plist>
