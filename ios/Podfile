platform :ios, '15.0'

use_frameworks!
use_modular_headers!

# Dummy function must be defined BEFORE it's used
def flutter_installation_placeholder
  # This is a no-op placeholder. Flutter plugins will be linked automatically.
end

target 'Runner' do
  flutter_installation_placeholder

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      end
    end
  end
end
