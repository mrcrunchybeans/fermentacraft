platform :ios, '15.0'

use_frameworks!
use_modular_headers!

target 'Runner' do
  flutter_install_plugins

  post_install do |installer|
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      end
    end
  end
end

# Define fallback plugin installer
def flutter_install_plugins
  # Do nothing – plugins are auto-managed by Flutter tools
end
