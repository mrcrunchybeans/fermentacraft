platform :ios, '15.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# ✅ FIX: point to ios/Flutter/podhelper relative to THIS file's directory
require File.expand_path('Flutter/podhelper', __dir__)

target 'Runner' do
  # These improve compatibility with many Flutter pods
  use_frameworks! :linkage => :dynamic
  use_modular_headers!

  # Standard Flutter CocoaPods wiring
  flutter_ios_podfile_setup
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  post_install do |installer|
    installer.pods_project.targets.each do |t|
      t.build_configurations.each do |config|
        # Keep deployment target aligned
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
        # Bitcode is deprecated; ensure it's off
        config.build_settings['ENABLE_BITCODE'] = 'NO'
        # Apple-Silicon simulator arch quirk
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
        # Helps with binary stability of vendored pods
        config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      end
      flutter_additional_ios_build_settings(t)
    end
  end
end
