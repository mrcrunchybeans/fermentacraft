platform :ios, '15.0'
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

# AppCircle.io optimizations
ENV['COCOAPODS_PARALLEL_CODE_SIGN'] = 'true'
ENV['COCOAPODS_INSTALL_IN_PARALLEL'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# Resolve FLUTTER_ROOT from ios/Flutter/Generated.xcconfig (created by `flutter pub get`)
def flutter_root
  gxc = File.expand_path(File.join('Flutter', 'Generated.xcconfig'), __dir__)
  unless File.exist?(gxc)
    raise "Generated.xcconfig must exist. Run `flutter pub get` before CocoaPods."
  end
  File.foreach(gxc) do |line|
    if (m = line.match(/FLUTTER_ROOT=(.*)/))
      return m[1].strip
    end
  end
  raise "FLUTTER_ROOT not found in Generated.xcconfig."
end

# Load Flutter's CocoaPods helper from the SDK
require File.expand_path('packages/flutter_tools/bin/podhelper', flutter_root)

# Flutter pre-target setup
flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks! :linkage => :dynamic
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # Call Flutter's hook if it exists (guard avoids the undefined-method crash)
  flutter_post_install(installer) if defined?(flutter_post_install)
  
  # Patch FirebaseFunctions for GTMSessionFetcher compatibility
  begin
    functions_swift_file = "Pods/FirebaseFunctions/FirebaseFunctions/Sources/Functions.swift"
    if File.exist?(functions_swift_file) && File.readable?(functions_swift_file)
      # Try to make the file writable first
      system("chmod +w \"#{functions_swift_file}\"") if !File.writable?(functions_swift_file) && system("which chmod")
      
      functions_content = File.read(functions_swift_file)
      # Check if we need to patch
      if functions_content.include?("import GTMSessionFetcherCore")
        # Try a different approach using system commands if regular File.write fails
        if File.writable?(functions_swift_file)
          patched_content = functions_content.gsub("import GTMSessionFetcherCore", "import GTMSessionFetcher")
          File.write(functions_swift_file, patched_content)
          puts "Patched FirebaseFunctions to use GTMSessionFetcher instead of GTMSessionFetcherCore"
        else
          # Try using sed instead
          system("sed -i '' 's/import GTMSessionFetcherCore/import GTMSessionFetcher/g' \"#{functions_swift_file}\"")
          puts "Patched FirebaseFunctions using sed command"
        end
      else
        puts "FirebaseFunctions already appears to be patched or doesn't need patching"
      end
    else
      puts "FirebaseFunctions Functions.swift file not found or not readable"
    end
  rescue => e
    # Log error but continue with the rest of the installation
    puts "Warning: Failed to patch FirebaseFunctions: #{e.message}"
  end

  # Your extra tweaks
  installer.pods_project.targets.each do |t|
    t.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
      config.build_settings['SWIFT_VERSION'] = '5.0'
      
      # AppCircle.io build optimizations
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'i386'
      config.build_settings['VALID_ARCHS'] = 'arm64 x86_64'
      
      # CI-friendly settings
      config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO' if ENV['AC_APPCIRCLE'] == 'true'

      defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] || '$(inherited)'
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = [defs, 'PERMISSION_CAMERA=1', 'PERMISSION_PHOTOS=1']

      if config.name == 'Debug'
        flags = Array(config.build_settings['OTHER_SWIFT_FLAGS'])
        config.build_settings['OTHER_SWIFT_FLAGS'] = flags + ['-D', 'DEBUG']
      end
      
      # AppCircle-specific optimizations
      if ENV['AC_APPCIRCLE'] == 'true'
        config.build_settings['ENABLE_TESTABILITY'] = 'YES'
        config.build_settings['GCC_OPTIMIZATION_LEVEL'] = '0' if config.name == 'Debug'
      end
    end
    # Keep Flutter's per-target extras when available
    flutter_additional_ios_build_settings(t) if defined?(flutter_additional_ios_build_settings)
  end
end