{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "Node",
    "lib": ["ES2020"],
    "outDir": "lib",
    "rootDir": "src",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]          // <-- fixes 'console' and Node globals
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "lib"]
}
